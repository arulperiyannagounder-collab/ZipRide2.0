{
  "manifest_version": 3,
  "name": "Ride Fairness Assistant",
  "version": "1.0.0",
  "description": "Analyzes ride fares and helps you determine if the price is fair and transparent.",
  "action": {
    "default_popup": "rapido/ride-fairness-extension/dist/index.html",
    "default_title": "Open Ride Fairness Assistant"
  },
  "background": {
    "service_worker": "rapido/ride-fairness-extension/dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["rapido/ride-fairness-extension/dist/content.js"]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.uber.com/*",
    "*://*.olacabs.com/*",
    "*://*.rapido.bike/*",
    "https://nominatim.openstreetmap.org/*"
  ]
}
